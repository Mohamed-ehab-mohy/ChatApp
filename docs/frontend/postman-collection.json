{
  "info": {
    "name": "ChatApp API",
    "description": "Real-time chat application backend. Uses JWT Bearer auth for REST endpoints.\nSignalR hub at /hub/chat for real-time messaging.\n\nLOCAL:\nBase URL: http://localhost:5111\nScalar UI : http://localhost:5111/scalar/v1\nOpenAPI  : http://localhost:5111/openapi/v1.json\n\nPRODUCTION (Railway):\nBase URL: https://chatapp-production-d621.up.railway.app\nScalar UI : https://chatapp-production-d621.up.railway.app/scalar/v1\nOpenAPI  : https://chatapp-production-d621.up.railway.app/openapi/v1.json\n\nChange the baseUrl variable value to switch environments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "ChatApp"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://chatapp-production-d621.up.railway.app",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },

  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints — no token required.",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Test123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Test123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" },
                { "key": "api-supported-versions", "value": "1.0" }
              ],
              "body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiIs...\",\n  \"email\": \"user@example.com\",\n  \"userId\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\"\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "Refresh Token",
      "description": "Refresh expired JWT token. Reads HttpOnly cookie automatically — no body needed. Ensure Postman cookie jar has the refresh_token cookie (from Register/Login).",
      "item": [
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
            }
          }
        }
      ]
    },
    {
      "name": "Logout",
      "description": "Revoke refresh token and clear the cookie.",
      "item": [
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Messages",
      "description": "Message endpoints — require JWT Bearer token.",
      "item": [
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/messages?limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "messages"],
              "query": [
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Number of messages to fetch (clamped 1–200)"
                }
              ]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n    \"content\": \"Hello! <b>bold</b> and <a href=\\\"https://example.com\\\">link</a>\",\n    \"senderEmail\": \"user@example.com\",\n    \"sentAt\": \"2026-07-06T20:30:00Z\"\n  }\n]"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "SignalR Chat Hub",
      "description": "WebSocket connection to /hub/chat with access_token query param.\nUse Postman WebSocket Request feature for this.",
      "item": [
        {
          "name": "Connect via WebSocket",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/hub/chat?access_token={{token}}",
              "host": ["{{baseUrl}}"],
              "path": ["hub", "chat"],
              "query": [
                {
                  "key": "access_token",
                  "value": "{{token}}"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
