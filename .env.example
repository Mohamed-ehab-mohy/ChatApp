# Railway auto-injects DATABASE_URL & PORT
# For local Docker Compose (docker-compose.yml):
DB_PASSWORD=your_secure_db_password_here
JWT_SECRET=your_jwt_secret_key_at_least_32_chars_long
AllowedOrigins__0=http://localhost:5173
AllowedOrigins__1=http://localhost:3000

# For Railway dashboard, set these env vars:
# JwtSettings__SecretKey=<secure-random-key>
# AllowedOrigins__0=https://<your-frontend-domain>
